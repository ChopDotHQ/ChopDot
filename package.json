{
  "name": "chopdot",
  "version": "1.0.0",
  "description": "ChopDot - Expense splitting and group financial management app with Polkadot blockchain integration",
  "type": "module",
  "scripts": {
    "dev": "supabase start && vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "npx playwright test",
    "e2e:reuse": "env -u CI npx playwright test",
    "test:coverage": "vitest run --coverage",
    "e2e:generate": "node scripts/generate-cypress-mvp-spec.mjs",
    "e2e:server": "VITE_DATA_SOURCE=local VITE_SUPABASE_STRICT=false vite --host 127.0.0.1 --port 4173",
    "smoke:five-flows": "node scripts/smoke-five-flows.cjs",
    "smoke:guest-invite-guard": "node scripts/smoke-guest-invite-guard.cjs",
    "smoke:run-suite": "node scripts/run-smoke-suite.cjs --suite all",
    "ci:audit": "npm audit --audit-level=high || (echo 'npm audit reported unresolved advisories that currently require breaking dependency changes; continuing CI with warning.' >&2)",
    "ci:fast": "npm run ci:audit && npm run lint && npm run type-check && npx vitest run && npm run build && (test -f scripts/audit-components-and-structure.mjs && node scripts/audit-components-and-structure.mjs || echo 'audit-components-and-structure.mjs not present; skipping audit step')",
    "ci:smoke:targeted": "node scripts/ci-smoke-targeted.cjs",
    "ci:release": "npm run ci:fast && npm run smoke:run-suite",
    "qa:core": "npm run build && node scripts/qa-core.cjs",
    "qa:explore": "npm run build && node scripts/qa-explore.cjs",
    "qa:probes": "node scripts/qa-probes.cjs",
    "qa:report": "node scripts/qa-report.cjs",
    "qa:all": "npm run qa:core && npm run qa:probes",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:tokens": "! rg -n \"#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})\" src --glob '!**/*.{png,jpg,jpeg,svg,webp,gif}' | rg -v 'var\\(' && ! rg -n 'accent-orange|gradient-orange' src",
    "lint:size": "bash scripts/check-file-size.sh 400",
    "lint:circular": "npx madge --circular --extensions ts,tsx src/",
    "verify:edge-functions": "./scripts/verify-edge-functions.sh",
    "db:setup": "./supabase-setup-local.sh",
    "db:pull": "bash -c 'set -a && source .env && supabase db pull --db-url \"$SUPABASE_DB_URL\" && npm run db:reset'",
    "db:push": "bash -c 'set -a && source .env && supabase db push --db-url \"$SUPABASE_DB_URL\"'",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.0",
    "@automerge/automerge-repo": "^2.4.0",
    "@crustio/type-definitions": "^1.3.0",
    "@polkadot/api": "^14.3.1",
    "@polkadot/extension-dapp": "^0.62.2",
    "@polkadot/react-identicon": "^3.7.3",
    "@polkadot/util": "^13.5.7",
    "@polkadot/util-crypto": "^13.5.7",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-aspect-ratio": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-context-menu": "^2.2.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-hover-card": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-menubar": "^1.1.4",
    "@radix-ui/react-navigation-menu": "^1.2.3",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@sentry/react": "^10.34.0",
    "@supabase/supabase-js": "^2.45.4",
    "@walletconnect/ethereum-provider": "^2.22.4",
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/sign-client": "^2.23.0",
    "@walletconnect/types": "^2.23.0",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "date-fns": "^3.6.0",
    "decimal.js": "^10.6.0",
    "embla-carousel-react": "^8.5.1",
    "ethers": "^6.15.0",
    "input-otp": "^1.4.1",
    "ipfs-http-client": "^60.0.1",
    "ipfs-only-hash": "^4.0.0",
    "lucide-react": "^0.460.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "pako": "^2.1.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.55.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.13.3",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.5",
    "vaul": "^1.1.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.2",
    "@types/pako": "^2.0.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.15",
    "cypress": "^15.11.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "hardhat": "^3.1.8",
    "jsdom": "^29.0.0",
    "knowns": "^0.10.3",
    "madge": "^8.0.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^4.0.15"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.53.3",
    "@tailwindcss/oxide-linux-x64-gnu": "4.1.17",
    "lightningcss-linux-x64-gnu": "1.30.2"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@11.3.0",
  "keywords": [
    "expense-splitting",
    "group-finance",
    "polkadot",
    "web3",
    "blockchain",
    "mobile-web-app"
  ],
  "author": "ChopDot Team",
  "license": "MIT"
}
