{
  "name": "polkadot-contract-lab",
  "private": true,
  "version": "0.1.0",
  "description": "Isolated Hardhat lab for experimenting with Polkadot Hub smart contracts",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:testnet": "hardhat ignition deploy ./ignition/modules/Storage.ts --network polkadotHubTestnet",
    "deploy:mainnet": "hardhat ignition deploy ./ignition/modules/Storage.ts --network polkadotHubMainnet",
    "deploy:closeout:testnet": "hardhat ignition deploy ./ignition/modules/CloseoutRegistry.ts --network polkadotHubTestnet",
    "deploy:closeout:mainnet": "hardhat ignition deploy ./ignition/modules/CloseoutRegistry.ts --network polkadotHubMainnet",
    "rpc:check": "node ./scripts/chain-health.mjs"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@parity/hardhat-polkadot": "^0.1.5",
    "@types/node": "^22.10.2",
    "dockerode": "^4.0.9",
    "hardhat": "^2.26.0",
    "solc": "0.8.28",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
